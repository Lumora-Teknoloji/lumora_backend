# Lumora Backend — Environment Variables
# cp .env.example .env

# ─── Servis ───────────────────────────────────────────────────────────
APP_ENV=production
HOST=0.0.0.0
PORT=8000

# ─── PostgreSQL ───────────────────────────────────────────────────────
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=lumora_db
POSTGRESQL_USERNAME=postgres
POSTGRESQL_PASSWORD=your-db-password-here

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ─── CORS / Frontend ─────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
COOKIE_DOMAIN=.yourdomain.com

# ─── Intelligence Mikro Servis ────────────────────────────────────────
# VPS'de Intelligence aynı sunucudaysa:
INTELLIGENCE_URL=http://localhost:8001
# VPS'de ayrı sunucudaysa:
# INTELLIGENCE_URL=http://intelligence.internal:8001
INTELLIGENCE_INTERNAL_KEY=change-this-to-a-strong-secret-key

# ─── AI API Anahtarları ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
SERPAPI_API_KEY=
FAL_API_KEY=

# ─── Monitoring ───────────────────────────────────────────────────────
WEBHOOK_URL=https://hooks.slack.com/...
ALERT_THRESHOLD_MINUTES=60

# ─── Scraper ─────────────────────────────────────────────────────────
SCRAPER_MIN_DELAY=2.0
SCRAPER_MAX_DELAY=5.0

# ─── Redis (yeni bot mimarisi için) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
AGENT_SECRET=change-this-to-a-strong-secret-key
